local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local pingId = {
	Drone = "rbxassetid://95428092249797",
	Camera = "rbxassetid://70956972762553",
	BreachCharge = "rbxassetid://107017238142850",
	RemoteC4 = "rbxassetid://131938694361268",
	ProximityAlarm = "rbxassetid://119002926213252",
	StickyCamera = "rbxassetid://107359883904453",
	Claymore = "rbxassetid://102628388684642",
}

local pingColor = {
	Drone = Color3.fromRGB(100, 100, 100),
	Camera = Color3.fromRGB(100, 100, 100),
	BreachCharge = Color3.fromRGB(100, 100, 100),
	RemoteC4 = Color3.fromRGB(100, 100, 100),
	ProximityAlarm = Color3.fromRGB(100, 100, 100),
	StickyCamera = Color3.fromRGB(100, 100, 100),
	Claymore = Color3.fromRGB(100, 100, 100),
}

local gadgetTypes = { "Drone", "Camera", "BreachCharge", "RemoteC4", "ProximityAlarm", "StickyCamera", "Claymore" }

local EspTable = {}
for _, gadgetType in ipairs(gadgetTypes) do
	EspTable[gadgetType] = { Enabled = false, Connections = {}, PingObjects = {} }
end

local gadgetConfigs = {
	Drone = { name = "Drone", part = nil },
	Camera = { name = "Camera", part = nil },
	BreachCharge = { name = "BreachCharge", part = "Root" },
	RemoteC4 = { name = "RemoteC4", part = "Root" },
	ProximityAlarm = { name = "ProximityAlarm", part = "Root" },
	StickyCamera = { name = "StickyCamera", part = "Root" },
	Claymore = { name = "Claymore", part = "Root" },
}

-- Safely destroy a ping and remove it from its table
local function safeDestroyPing(gadgetType, model)
	if not EspTable[gadgetType] then return end
	local ping = EspTable[gadgetType].PingObjects[model]
	if ping then
		pcall(function()
			if ping.Parent then
				ping:Destroy()
			end
		end)
		EspTable[gadgetType].PingObjects[model] = nil
	end
end

local function createPingObject(gadgetType, parent, model, attachTo)
	if not pingId[gadgetType] or not pingColor[gadgetType] then
		warn("[ESP] No pingId/pingColor for gadgetType:", gadgetType)
		return nil
	end

	local pingModule = ReplicatedStorage:FindFirstChild("Modules")
		and ReplicatedStorage.Modules:FindFirstChild("Effects")
		and ReplicatedStorage.Modules.Effects:FindFirstChild("PingObject")

	if not pingModule then
		warn("[ESP] PingObject module not found in ReplicatedStorage.Modules.Effects")
		return nil
	end

	local ok, pingClone = pcall(function() return pingModule:Clone() end)
	if not ok or not pingClone then
		warn("[ESP] Failed to clone PingObject")
		return nil
	end

	local success = pcall(function()
		pingClone.Parent = parent
		pingClone.Adornee = attachTo or model
		pingClone.Enabled = true
		pingClone.Frame.BackgroundColor3 = pingColor[gadgetType]
		pingClone.Arrow.ImageColor3 = pingColor[gadgetType]
		pingClone.Frame.ImageLabel.Image = pingId[gadgetType]
	end)

	if not success then
		warn("[ESP] Failed to configure PingObject for:", gadgetType)
		pcall(function() pingClone:Destroy() end)
		return nil
	end

	return pingClone
end

local function setupCameraESP()
	local ok, err = pcall(function()
		for _, model in ipairs(Workspace:GetChildren()) do
			if model:IsA("Model") then
				local folder = model:FindFirstChildWhichIsA("Folder")
				if folder then
					local defaultCameras = folder:FindFirstChild("DefaultCameras")
					if defaultCameras then
						for _, cameraModel in ipairs(defaultCameras:GetChildren()) do
							if cameraModel:IsA("Model") and not EspTable.Camera.PingObjects[cameraModel] then
								local ping = createPingObject("Camera", Workspace.CurrentCamera, cameraModel)
								if ping then
									EspTable.Camera.PingObjects[cameraModel] = ping
									local camPart = cameraModel:FindFirstChild("Cam")
									if camPart and ping:FindFirstChild("testname") then
										pcall(function() ping.testname = camPart end)
									end
								end
							end
						end
					end
				end
			end
		end
	end)
	if not ok then warn("[ESP] setupCameraESP error:", err) end
end

local function setupGadgetESP(gadgetType)
	local config = gadgetConfigs[gadgetType]
	if not config then
		warn("[ESP] No config for gadgetType:", gadgetType)
		return
	end

	local ok, err = pcall(function()
		for _, model in ipairs(Workspace:GetChildren()) do
			if model.Name == config.name and model:IsA("Model") then
				if not EspTable[gadgetType].PingObjects[model] then
					local attachPart = config.part and model:FindFirstChild(config.part)
					local ping = createPingObject(gadgetType, Workspace.CurrentCamera, model, attachPart)
					if ping then
						EspTable[gadgetType].PingObjects[model] = ping
					end
				end
			end
		end
	end)
	if not ok then warn("[ESP] setupGadgetESP error for", gadgetType, ":", err) end
end

local function cleanupPings(gadgetType)
	if not EspTable[gadgetType] then return end
	local pingTable = EspTable[gadgetType].PingObjects
	for model, _ in pairs(pingTable) do
		safeDestroyPing(gadgetType, model)
	end
	EspTable[gadgetType].PingObjects = {}
end

local function createGadgetConnection(gadgetType)
	local config = gadgetConfigs[gadgetType]
	if not config or not EspTable[gadgetType] then
		warn("[ESP] Cannot create connection, missing config or EspTable for:", gadgetType)
		return
	end

	EspTable[gadgetType].Connections.childAdded = Workspace.ChildAdded:Connect(function(child)
		if not EspTable[gadgetType] or not EspTable[gadgetType].Enabled then return end
		if child.Name ~= config.name or not child:IsA("Model") then return end

		task.wait(0.1)

		-- Guard: child may have been removed during the wait
		if not child or not child.Parent then return end

		pcall(function()
			local attachPart = config.part and child:FindFirstChild(config.part)
			local ping = createPingObject(gadgetType, Workspace.CurrentCamera, child, attachPart)
			if ping then
				EspTable[gadgetType].PingObjects[child] = ping
			end
		end)
	end)

	EspTable[gadgetType].Connections.childRemoved = Workspace.ChildRemoved:Connect(function(child)
		safeDestroyPing(gadgetType, child)
	end)
end

-- Set up connections for all non-camera gadgets
for gadgetType, _ in pairs(gadgetConfigs) do
	if gadgetType ~= "Camera" then
		createGadgetConnection(gadgetType)
	end
end

-- Camera connections
EspTable.Camera.Connections.childAdded = Workspace.ChildAdded:Connect(function(child)
	if not EspTable.Camera.Enabled or not child:IsA("Model") then return end
	task.wait(0.1)
	if child and child.Parent then
		setupCameraESP()
	end
end)

EspTable.Camera.Connections.childRemoved = Workspace.ChildRemoved:Connect(function(child)
	safeDestroyPing("Camera", child)
end)

local function updateESP(gadgetType, state)
	if not EspTable[gadgetType] then
		warn("[ESP] updateESP called with unknown gadgetType:", gadgetType)
		return
	end

	EspTable[gadgetType].Enabled = state

	if state then
		if gadgetType == "Camera" then
			setupCameraESP()
		else
			setupGadgetESP(gadgetType)
		end
	else
		cleanupPings(gadgetType)
	end
end

-- Build the public Esp API
local Esp = {}

for _, gadgetType in ipairs(gadgetTypes) do
	if not EspTable[gadgetType] then
		warn("[ESP] Skipping Esp entry for unknown gadgetType:", gadgetType)
		continue
	end

	Esp[gadgetType] = {
		getEnabled = function()
			return EspTable[gadgetType] and EspTable[gadgetType].Enabled or false
		end,
		setEnabled = function(state)
			updateESP(gadgetType, state)
		end,
	}

	setmetatable(Esp[gadgetType], {
		__index = function(self, key)
			if key == "Enabled" then
				return EspTable[gadgetType] and EspTable[gadgetType].Enabled or false
			end
			return rawget(Esp[gadgetType], key)
		end,
		__newindex = function(self, key, value)
			if key == "Enabled" then
				updateESP(gadgetType, value)
			else
				rawset(self, key, value)
			end
		end,
	})
end

return Esp
